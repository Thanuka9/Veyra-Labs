# Public site URL (optional — defaults to https://veyralabs.com)
# Set to your ngrok URL when tunneling: https://abc123.ngrok-free.app
NEXT_PUBLIC_SITE_URL=

# EmailJS — contact form, chat leads & estimate emails
# Use ONLY the Public Key. Never put the Private Key in NEXT_PUBLIC_* vars,
# GitHub, Vercel client env, or any frontend code.
#
# Templates (EmailJS dashboard):
#   Internal lead (to Veyra):  template_neuqpqj
#     To Email → veyralabs0@gmail.com  (fixed)
#     From Name → {{from_name}}
#     Reply-To → {{reply_to}}   (= customer email)
#     Subject  → {{subject}}
#     Body email link → mailto:{{reply_to}}  (shows customer address)
#     Attachment (estimates): Variable Attachment
#       Parameter name: estimate_pdf
#       Filename: {{estimate_filename}}
#       Content type: PDF
#
#   Customer confirmation: template_69hvz1j
#     To Email → {{to_email}}  (= customer)
#     From Name → Veyra Labs
#     Reply-To → {{reply_to}}  (= veyralabs0@gmail.com — NOT the customer)
#     Subject  → {{subject}}
#     Body     → {{name}} {{message}} {{company}} — use {{to_email}} if showing their address
#     Attachment → same estimate_pdf / {{estimate_filename}} for estimate flow
#
# Contact/inquiry emails intentionally do NOT send estimate_pdf.
#
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_your_service_id
NEXT_PUBLIC_EMAILJS_INTERNAL_TEMPLATE_ID=template_neuqpqj
NEXT_PUBLIC_EMAILJS_CONFIRMATION_TEMPLATE_ID=template_69hvz1j
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_new_public_key

# Google Analytics 4 (optional — leave empty to disable)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console site verification (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
