# Public site URL (optional — defaults to https://veyralabs.com)
# Set to your ngrok URL when tunneling: https://abc123.ngrok-free.app
NEXT_PUBLIC_SITE_URL=

# EmailJS — contact form, chat leads & estimate emails
# Use ONLY the Public Key. Never put the Private Key in NEXT_PUBLIC_* vars,
# GitHub, Vercel client env, or any frontend code.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_your_service_id
NEXT_PUBLIC_EMAILJS_INTERNAL_TEMPLATE_ID=template_neuqpqj
NEXT_PUBLIC_EMAILJS_CONFIRMATION_TEMPLATE_ID=template_69hvz1j
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_new_public_key

# Google Analytics 4 (optional — leave empty to disable)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console site verification (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
