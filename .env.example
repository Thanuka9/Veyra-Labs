# Neon / Postgres — required to track every estimate / quote ID
# 1. Create a free DB at https://neon.tech
# 2. Run the SQL in sql/estimates.sql
# 3. Paste ONLY the connection string (starts with postgresql://…)
#    In Vercel Value field: do NOT include "DATABASE_URL=" — only the URL itself
#    Use your real Neon password (not YOUR_PASSWORD)
DATABASE_URL=

# Public site URL (optional — defaults to https://veyralabs.com)
# Set to your ngrok URL when tunneling: https://abc123.ngrok-free.app
NEXT_PUBLIC_SITE_URL=

# EmailJS — contact form, chat leads & estimate emails
# Use ONLY the Public Key. Never put the Private Key in NEXT_PUBLIC_* vars,
# GitHub, Vercel client env, or any frontend code.
#
# Templates (EmailJS dashboard) — leave Attachments empty on both.
#
#   Customer confirmation: template_69hvz1j
#     Subject  → {{subject}}
#     To Email → {{to_email}}
#     From Name → Veyra Labs
#     Reply-To → {{reply_to}}  (= veyralabs0@gmail.com for customer emails)
#     Use {{#is_estimate}} / {{#is_inquiry}} for conditional body blocks
#     Do NOT claim a PDF is attached — summary is in {{message}}
#
#   Internal lead: template_neuqpqj
#     Subject  → {{subject}}
#     To Email → veyralabs0@gmail.com  (fixed)
#     From Name → Veyra Website
#     Reply-To → {{reply_to}}  (= customer email)
#
# PDF download is on-site only (Download PDF button). Emails are attachment-free.
#
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_your_service_id
NEXT_PUBLIC_EMAILJS_INTERNAL_TEMPLATE_ID=template_neuqpqj
NEXT_PUBLIC_EMAILJS_CONFIRMATION_TEMPLATE_ID=template_69hvz1j
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_new_public_key

# Google Analytics 4 (optional — leave empty to disable)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console site verification (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
